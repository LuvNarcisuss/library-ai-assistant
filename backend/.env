# 应用配置
APP_NAME=Library AI Assistant
APP_VERSION=0.1.0
DEBUG=true

# 数据库
DATABASE_URL=sqlite:///D:/aelm/deeplearning/library-ai-assistant/backend/app/data/library.db

# JWT 认证
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 向量库
CHROMA_PERSIST_DIR=D:/aelm/deeplearning/library-ai-assistant/backend/app/data/chroma

# Embedding 模型
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# 文本拆分参数
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# RAG 检索参数
TOP_K=3
SIMILARITY_THRESHOLD=0.3

# LLM 配置
LLM_API_KEY=sk-2d647075281343b4aef0ac69a87a1cb3
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024
